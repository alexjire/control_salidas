<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.controlbano.control_salidas.controllerfx.ScannerController"
           stylesheets="@/styles/app.css"
           styleClass="root-background">

    <!-- LOGO SUPERIOR IZQUIERDO -->
    <HBox alignment="TOP_LEFT"
          StackPane.alignment="TOP_LEFT"
          style="-fx-padding: 25 25 25 60;">
        <ImageView fitHeight="75" preserveRatio="true">
            <image>
                <Image url="@/static/img/Logo-Camtronics.png"/>
            </image>
        </ImageView>
    </HBox>

    <!-- CONTENEDOR GLASS -->
    <VBox spacing="25"
          alignment="TOP_CENTER"
          maxWidth="1800"
          prefHeight="900"
          VBox.vgrow="ALWAYS"
          styleClass="glass-card">

        <Label text="CONTROL DE SALIDAS"
               styleClass="title-label"/>

        <Label fx:id="lblReloj"
               styleClass="clock-label"/>

        <TextField fx:id="txtCarnet"
                   promptText="Escanee o escriba el carnet"
                   maxWidth="300"
                   prefWidth="300"
                   styleClass="input-field"/>

        <Label fx:id="lblResultado"
               wrapText="true"
               alignment="CENTER"
               styleClass="result-label"/>

        <!-- ⭐ TABLA MÁS ALTA (CAMBIO PRINCIPAL) -->
        <TableView fx:id="tablaRegistros"
                   VBox.vgrow="ALWAYS"
                   prefHeight="700">

            <columns>
                <TableColumn fx:id="colCarnet" text="Carnet"/>
                <TableColumn fx:id="colNombre" text="Nombre"/>
                <TableColumn fx:id="colSalida" text="Salida"/>
                <TableColumn fx:id="colEntrada" text="Entrada"/>
                <TableColumn fx:id="colDuracion" text="Duración"/>
                <TableColumn fx:id="colEstado" text="Estado"/>
            </columns>

        </TableView>

        <Button text="Cerrar Sesión"
                onAction="#salirLogin"
                prefWidth="240"
                styleClass="primary-button"/>

        <!-- FOOTER -->
        <VBox alignment="CENTER"
              spacing="12"
              styleClass="footer-box">

            <ImageView fitHeight="75" preserveRatio="true">
                <image>
                    <Image url="@/static/img/Logo-Personal.png"/>
                </image>
            </ImageView>

            <Label text="Sistema Empresarial de Control de Salidas"
                   styleClass="footer-title"/>

            <Label text="Desarrollado por José A. Jimenez Reyes"
                   styleClass="footer-subtitle"/>

            <Label text="© 2026 Todos los derechos reservados"
                   styleClass="footer-subtitle"/>

        </VBox>

    </VBox>

</StackPane>