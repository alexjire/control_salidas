<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="25"
      alignment="CENTER"
      style="-fx-padding: 40; -fx-background-color: #f5f5f5;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.controlbano.control_salidas.controllerfx.ScannerController">

    <Label text="Control de Salidas al Baño"
           style="-fx-font-size:26px;-fx-font-weight:bold;"/>

    <TextField fx:id="txtCarnet"
               promptText="Escanee o escriba el carnet"
               style="-fx-font-size:18px;"
               maxWidth="350"/>

    <Label fx:id="lblResultado"
           wrapText="true"
           style="-fx-font-size:28px;
                  -fx-font-weight:bold;
                  -fx-text-fill:#2c3e50;"/>

    <TableView fx:id="tablaRegistros" prefHeight="300" maxWidth="900">

        <columns>

            <TableColumn fx:id="colCarnet" text="Carnet" prefWidth="120"/>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="220"/>
            <TableColumn fx:id="colSalida" text="Salida" prefWidth="180"/>
            <TableColumn fx:id="colEntrada" text="Entrada" prefWidth="180"/>
            <TableColumn fx:id="colDuracion" text="Duración" prefWidth="120"/>
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>

        </columns>

    </TableView>

    <HBox spacing="20" alignment="CENTER">

        <Button text="Salir"
                onAction="#salirLogin"
                prefWidth="150"
                style="-fx-font-size:16px;"/>

    </HBox>

</VBox>